<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_leave_view_form_select_employee" model="ir.ui.view">
        <field name="name">hr.leave.view.form.select.employee</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form"/>
        <field name="arch" type="xml">
            
            <!-- 1. Hacer visible el contenedor 'title' -->
            <xpath expr="//div[@name='title']" position="attributes">
                <attribute name="invisible">0</attribute>
            </xpath>

            <!-- 2. Hacer visible, editable el campo employee_ids y ponerle el widget de etiquetas -->
            <xpath expr="//div[@name='title']/field[@name='employee_ids']" position="attributes">
                <attribute name="invisible">0</attribute>
                <attribute name="readonly">0</attribute>
                <attribute name="widget">many2many_tags</attribute>
            </xpath>

        </field>
    </record>
</odoo>