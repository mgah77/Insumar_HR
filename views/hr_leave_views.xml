<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_leave_form_allow_employee_selection" model="ir.ui.view">
        <field name="name">hr.leave.form.allow.employee.selection</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form"/>
        <field name="arch" type="xml">
            
            <!-- Interceptamos el campo employee_id y le quitamos los atributos restrictivos -->
            <xpath expr="//field[@name='employee_id']" position="attributes">
                <!-- Forzamos a que no esté oculto y se pueda editar -->
                <attribute name="invisible">0</attribute>
                <attribute name="readonly">0</attribute>
                
                <!-- Eliminamos el dominio que limita la búsqueda solo al usuario actual -->
                <attribute name="domain">[('active', '=', True)]</attribute>
            </xpath>

        </field>
    </record>
</odoo>